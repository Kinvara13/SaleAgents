APP_NAME=Bid Agent API
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
API_PREFIX=/api/v1
FRONTEND_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000/api/v1

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bid_agent
POSTGRES_USER=bid_agent
POSTGRES_PASSWORD=bid_agent
DATABASE_URL_OVERRIDE=
# SQLite fallback example:
# DATABASE_URL_OVERRIDE=sqlite:///./bid_agent.db

REDIS_HOST=localhost
REDIS_PORT=6379

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bid-agent

LLM_ENABLED=true
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=45
LLM_MAX_REVIEW_ISSUES=5
